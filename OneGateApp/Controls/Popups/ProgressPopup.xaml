<?xml version="1.0" encoding="utf-8" ?>
<og:MyPopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:og="http://schemas.neoorder.org/onegate/controls"
            xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
            x:Class="NeoOrder.OneGate.Controls.Popups.ProgressPopup"
            x:TypeArguments="x:Boolean"
            SafeAreaEdges="All"
            BindingContext="{Binding Source={RelativeSource Self}}">
    <VerticalStackLayout Spacing="16" WidthRequest="260">
        <Label Text="{Binding Title}" FontAttributes="Bold" MaxLines="1" />
        <Grid ColumnDefinitions="auto,*" ColumnSpacing="14">
            <ActivityIndicator IsRunning="True"
                               WidthRequest="24"
                               HeightRequest="24"
                               Color="{toolkit:AppThemeResource Secondary}" />
            <Label Grid.Column="1"
                   Text="{Binding Message}"
                   VerticalOptions="Center"
                   LineBreakMode="WordWrap" />
        </Grid>
    </VerticalStackLayout>
</og:MyPopup>
