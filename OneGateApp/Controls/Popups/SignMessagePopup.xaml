<?xml version="1.0" encoding="utf-8" ?>
<og:MyPopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:og="http://schemas.neoorder.org/onegate/controls"
            xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
            x:Class="NeoOrder.OneGate.Controls.Popups.SignMessagePopup"
            x:TypeArguments="x:String"
            BindingContext="{Binding Source={RelativeSource Self}}">
    <og:MyPopup.Resources>
        <toolkit:IsNullConverter x:Key="IsNullConverter" />
        <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
    </og:MyPopup.Resources>
    <VerticalStackLayout Spacing="15" MaximumWidthRequest="450">
        <Grid ColumnDefinitions="*,auto">
            <Label Text="{x:Static og:Strings.SignMessage}" FontAttributes="Bold" />
            <Button Grid.Column="1" StyleClass="Icon" Text="&#xe6b5;" FontSize="24" Margin="-10" Padding="10" Clicked="OnCancel" />
        </Grid>
        <Label Text="{x:Static og:Strings.SignMessageText}" />
        <Border StrokeShape="RoundRectangle 8" BackgroundColor="#fdf0d5" Padding="10">
            <Grid ColumnDefinitions="auto,*" ColumnSpacing="10">
                <Label StyleClass="Icon" Text="&#xe744;" FontSize="18" TextColor="#b8860b" VerticalOptions="Start" />
                <Label Grid.Column="1" Text="{x:Static og:Strings.SignMessageRiskWarning}" TextColor="#7a5a00" FontSize="12" LineBreakMode="WordWrap" />
            </Grid>
        </Border>
        <Label>
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="{x:Static og:Strings.SigningAccount}" />
                    <Span Text=":" />
                </FormattedString>
            </Label.FormattedText>
        </Label>
        <Label StyleClass="Secondary" Margin="0,-10,0,0" Text="{Binding Account}" IsVisible="{Binding Account, Converter={StaticResource IsNotNullConverter}}" />
        <Picker x:Name="pickerAddress" Margin="0,-10,0,0" IsVisible="{Binding Account, Converter={StaticResource IsNullConverter}}" MinimumHeightRequest="0" VerticalOptions="Center" Title="{x:Static og:Strings.SelectAddressFromWallet}" ItemsSource="{Binding Addresses}" SelectedItem="{Binding Account, Mode=OneWayToSource}" />
        <og:ValidationMessage Title="{x:Static og:Strings.Address}" Margin="0,-15,0,0" Target="{x:Reference pickerAddress}" IsEnabled="{Binding Account, Converter={StaticResource IsNullConverter}}">
            <og:Required />
        </og:ValidationMessage>
        <Label>
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="{x:Static og:Strings.Message}" />
                    <Span Text=":" />
                </FormattedString>
            </Label.FormattedText>
        </Label>
        <Border Margin="0,-10,0,0" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="10">
            <ScrollView HeightRequest="100">
                <Label StyleClass="Secondary" Text="{Binding Message}" />
            </ScrollView>
        </Border>
        <VerticalStackLayout Spacing="5" IsVisible="{Binding HasReadableMessage}">
            <Label StyleClass="Secondary" Text="{x:Static og:Strings.DecodedMessage}" FontSize="11" />
            <Border Margin="0,-5,0,0" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="10">
                <ScrollView HeightRequest="80">
                    <Label Text="{Binding ReadableMessage}" />
                </ScrollView>
            </Border>
        </VerticalStackLayout>
        <Grid ColumnDefinitions="*,auto,*" Margin="-15,0,-15,-15">
            <BoxView Grid.ColumnSpan="3" HeightRequest="1" VerticalOptions="Start" />
            <Button Grid.Column="0" StyleClass="Secondary" Text="{x:Static og:Strings.Cancel}" BorderWidth="0" Clicked="OnCancel" />
            <BoxView Grid.Column="1" WidthRequest="1" VerticalOptions="Fill" />
            <og:Submit Grid.Column="2" Text="{x:Static og:Strings.Continue}" TextColor="#5676e7" ButtonColor="Transparent" Submitted="OnSubmit" />
        </Grid>
    </VerticalStackLayout>
</og:MyPopup>
