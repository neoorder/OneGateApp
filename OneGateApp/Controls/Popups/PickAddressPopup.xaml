<?xml version="1.0" encoding="utf-8" ?>
<og:MyPopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:og="http://schemas.neoorder.org/onegate/controls"
            xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
            x:Class="NeoOrder.OneGate.Controls.Popups.PickAddressPopup"
            x:TypeArguments="x:String"
            BindingContext="{Binding Source={RelativeSource Self}}">
    <VerticalStackLayout Spacing="15">
        <Grid ColumnDefinitions="*,auto">
            <Label Text="{x:Static og:Strings.PickAddress}" FontAttributes="Bold" />
            <Button Grid.Column="1" StyleClass="Icon" Text="&#xe6b5;" FontSize="24" Margin="-10" Padding="10" Clicked="OnCancel" />
        </Grid>
        <Label Text="{Binding Message}" />
        <Grid ColumnDefinitions="auto,*" RowDefinitions="auto,auto" RowSpacing="15">
            <RadioButton x:Name="radio1" Grid.Column="0" Grid.Row="0" MinimumHeightRequest="0" VerticalOptions="Center" IsChecked="True" />
            <RadioButton x:Name="radio2" Grid.Column="0" Grid.Row="1" MinimumHeightRequest="0" VerticalOptions="Center" />
            <Picker x:Name="pickerAddress" Grid.Column="1" Grid.Row="0" MinimumHeightRequest="0" VerticalOptions="Center" IsEnabled="{Binding IsChecked, Source={x:Reference radio1}}" Title="{x:Static og:Strings.SelectAddressFromWallet}" ItemsSource="{Binding Addresses}" />
            <Entry x:Name="entryAddress" Grid.Column="1" Grid.Row="1" MinimumHeightRequest="0" VerticalOptions="Center" IsEnabled="{Binding IsChecked, Source={x:Reference radio2}}" Placeholder="{x:Static og:Strings.EnterCustomAddress}" />
        </Grid>
        <og:ValidationMessage Title="{x:Static og:Strings.Address}" Margin="0,-15,0,0" Target="{x:Reference pickerAddress}" IsEnabled="{Binding IsChecked, Source={x:Reference radio1}}">
            <og:Required />
        </og:ValidationMessage>
        <og:ValidationMessage Title="{x:Static og:Strings.Address}" Margin="0,-15,0,0" Target="{x:Reference entryAddress}" IsEnabled="{Binding IsChecked, Source={x:Reference radio2}}">
            <og:Required />
            <og:Custom Validate="OnValidateAddress" />
        </og:ValidationMessage>
        <BoxView HeightRequest="1" Margin="-15,0" />
        <Grid ColumnDefinitions="*,auto,*" Margin="-15">
            <Button Grid.Column="0" StyleClass="Secondary" Text="{x:Static og:Strings.Cancel}" BorderWidth="0" Clicked="OnCancel" />
            <BoxView Grid.Column="1" WidthRequest="1" VerticalOptions="Fill" />
            <og:Submit Grid.Column="2" Text="{x:Static og:Strings.OK}" TextColor="#5676e7" ButtonColor="Transparent" Submitted="OnSubmit" />
        </Grid>
    </VerticalStackLayout>
</og:MyPopup>
