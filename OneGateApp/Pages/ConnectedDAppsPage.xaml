<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.ConnectedDAppsPage"
             Title="{x:Static og:Strings.ConnectedDApps}"
             Shell.TabBarIsVisible="False">
    <CollectionView Margin="20" ItemsSource="{Binding Grants}">
        <CollectionView.EmptyView>
            <Label Text="{x:Static og:Strings.NoConnectedDApps}" HorizontalOptions="Center" />
        </CollectionView.EmptyView>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="og:ConnectedDAppPermissionItem">
                <Border StrokeShape="RoundRectangle 10" Padding="10" Margin="0,0,0,15">
                    <Grid ColumnDefinitions="*,auto" ColumnSpacing="15">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Host}" FontAttributes="Bold" />
                            <Label StyleClass="Secondary" Text="{Binding DisplayLastUsedAt}" FontSize="12" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                StyleClass="Secondary"
                                Text="{x:Static og:Strings.Disconnect}"
                                BorderWidth="0"
                                Clicked="OnDisconnectClicked"
                                CommandParameter="{Binding Host}" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
