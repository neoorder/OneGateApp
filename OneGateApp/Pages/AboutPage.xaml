<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.AboutPage"
             Title="{x:Static og:Strings.AboutOneGate}"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="auto,auto,*" RowSpacing="20" Margin="20">
        <Image Source="logo_vertical.png" WidthRequest="128" />
        <Label Grid.Row="1" StyleClass="Secondary" Text="{Binding AppInfo.VersionString}" HorizontalOptions="Center" />
        <og:SettingsView Grid.Row="2" Settings="{Binding SettingEntries}" />
        <Grid.Behaviors>
            <og:KonamiCodeBehavior KonamiCodeEntered="OnKonamiCodeEntered" />
        </Grid.Behaviors>
    </Grid>
</ContentPage>