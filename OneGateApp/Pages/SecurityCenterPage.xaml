<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="NeoOrder.OneGate.Pages.SecurityCenterPage"
             Title="{x:Static og:Strings.SecurityCenter}"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
        <ScrollView>
            <VerticalStackLayout Margin="20,20,20,120" Spacing="18">
                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{toolkit:AppThemeResource Panel}" Padding="18">
                    <Grid ColumnDefinitions="auto,*" ColumnSpacing="14">
                        <Border StrokeShape="Ellipse" BackgroundColor="{toolkit:AppThemeResource Primary}" WidthRequest="48" HeightRequest="48" VerticalOptions="Start">
                            <Label StyleClass="Icon" Text="&#xe744;" TextColor="{toolkit:AppThemeResource Accent}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="{x:Static og:Strings.SecurityCenterSummaryTitle}" FontAttributes="Bold" FontSize="20" />
                            <Label StyleClass="Secondary" Text="{x:Static og:Strings.SecurityCenterSummaryText}" LineBreakMode="WordWrap" />
                            <Label StyleClass="Secondary" Text="{Binding LastCheckedText}" FontSize="12" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Label StyleClass="Secondary" Text="{x:Static og:Strings.SecurityStatus}" />
                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{toolkit:AppThemeResource Panel}">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="auto,*,auto" RowDefinitions="auto,auto" ColumnSpacing="14" RowSpacing="4" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe744;" FontSize="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static og:Strings.BackupStatus}" FontAttributes="Bold" />
                            <Switch Grid.Column="2" Grid.RowSpan="2" IsToggled="{Binding IsBackupConfirmed}" Toggled="OnBackupConfirmedToggled" VerticalOptions="Center" />
                            <Label Grid.Column="1" Grid.Row="1" StyleClass="Secondary" Text="{Binding BackupStatusText}" FontSize="12" LineBreakMode="WordWrap" />
                        </Grid>
                        <BoxView HeightRequest="1" />
                        <Grid ColumnDefinitions="auto,*,auto" RowDefinitions="auto,auto" ColumnSpacing="14" RowSpacing="4" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe744;" FontSize="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static og:Strings.PasswordStatus}" FontAttributes="Bold" />
                            <Label Grid.Column="2" Text="{x:Static og:Strings.PasswordProtected}" FontAttributes="Bold" HorizontalOptions="End" />
                            <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" StyleClass="Secondary" Text="{x:Static og:Strings.PasswordProtectedText}" FontSize="12" LineBreakMode="WordWrap" />
                        </Grid>
                        <BoxView HeightRequest="1" />
                        <Grid ColumnDefinitions="auto,*,auto" RowDefinitions="auto,auto" ColumnSpacing="14" RowSpacing="4" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe67f;" FontSize="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static og:Strings.BiometricStatus}" FontAttributes="Bold" />
                            <Label Grid.Column="2" Text="{Binding BiometricStatus}" FontAttributes="Bold" HorizontalOptions="End" />
                            <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" StyleClass="Secondary" Text="{Binding BiometricStatusText}" FontSize="12" LineBreakMode="WordWrap" />
                        </Grid>
                        <BoxView HeightRequest="1" />
                        <Grid ColumnDefinitions="auto,*,auto" RowDefinitions="auto,auto" ColumnSpacing="14" RowSpacing="4" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe901;" FontSize="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static og:Strings.NetworkStatus}" FontAttributes="Bold" />
                            <Label Grid.Column="2" Text="{Binding RpcStatus}" FontAttributes="Bold" HorizontalOptions="End" />
                            <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" StyleClass="Secondary" Text="{Binding RpcStatusText}" FontSize="12" LineBreakMode="WordWrap" />
                        </Grid>
                        <BoxView HeightRequest="1" />
                        <Grid ColumnDefinitions="auto,*,auto" RowDefinitions="auto,auto" ColumnSpacing="14" RowSpacing="4" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xeadb;" FontSize="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static og:Strings.PrivacyMode}" FontAttributes="Bold" />
                            <Switch Grid.Column="2" Grid.RowSpan="2" IsToggled="{Binding IsPrivacyModeEnabled}" Toggled="OnPrivacyModeToggled" VerticalOptions="Center" />
                            <Label Grid.Column="1" Grid.Row="1" StyleClass="Secondary" Text="{x:Static og:Strings.PrivacyModeText}" FontSize="12" LineBreakMode="WordWrap" />
                        </Grid>
                        <BoxView HeightRequest="1" />
                        <Grid ColumnDefinitions="auto,*,auto" RowDefinitions="auto,auto" ColumnSpacing="14" RowSpacing="4" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe853;" FontSize="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static og:Strings.DAppAuthorization}" FontAttributes="Bold" />
                            <Label Grid.Column="2" Text="{x:Static og:Strings.DAppAuthorizationStatus}" FontAttributes="Bold" HorizontalOptions="End" />
                            <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" StyleClass="Secondary" Text="{x:Static og:Strings.DAppAuthorizationText}" FontSize="12" LineBreakMode="WordWrap" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label StyleClass="Secondary" Text="{x:Static og:Strings.SecurityActions}" />
                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{toolkit:AppThemeResource Panel}">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="14" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe744;" FontSize="20" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{x:Static og:Strings.ReviewBackup}" FontAttributes="Bold" />
                                <Label StyleClass="Secondary" Text="{x:Static og:Strings.ReviewBackupText}" FontSize="12" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" StyleClass="Icon, Secondary" Text="&#xe70a;" FontSize="12" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnReviewBackupTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView HeightRequest="1" />
                        <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="14" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe744;" FontSize="20" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{x:Static og:Strings.ManageWalletPassword}" FontAttributes="Bold" />
                                <Label StyleClass="Secondary" Text="{x:Static og:Strings.ManageWalletPasswordText}" FontSize="12" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" StyleClass="Icon, Secondary" Text="&#xe70a;" FontSize="12" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnManagePasswordTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView HeightRequest="1" />
                        <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="14" Padding="16,14" IsVisible="{Binding IsBiometricAvailable}">
                            <Label StyleClass="Icon, Secondary" Text="&#xe67f;" FontSize="20" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{x:Static og:Strings.ManageBiometrics}" FontAttributes="Bold" />
                                <Label StyleClass="Secondary" Text="{Binding BiometricActionText}" FontSize="12" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" StyleClass="Icon, Secondary" Text="&#xe70a;" FontSize="12" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnManageBiometricsTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView HeightRequest="1" IsVisible="{Binding IsBiometricAvailable}" />
                        <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="14" Padding="16,14">
                            <Label StyleClass="Icon, Secondary" Text="&#xe853;" FontSize="20" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{x:Static og:Strings.ReviewDApps}" FontAttributes="Bold" />
                                <Label StyleClass="Secondary" Text="{x:Static og:Strings.ReviewDAppsText}" FontSize="12" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" StyleClass="Icon, Secondary" Text="&#xe70a;" FontSize="12" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnReviewDAppsTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
