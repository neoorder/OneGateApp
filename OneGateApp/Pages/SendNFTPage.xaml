<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="NeoOrder.OneGate.Pages.SendNFTPage"
             Title="{x:Static og:Strings.Send}"
             SafeAreaEdges="All"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <Grid Margin="20" RowDefinitions="*,auto" RowSpacing="20">
        <ScrollView>
            <VerticalStackLayout Spacing="18">
                <VerticalStackLayout Spacing="8">
                    <Label StyleClass="Secondary" Text="NFT" FontAttributes="Bold" />
                    <Border StyleClass="Card" Padding="14">
                        <Grid ColumnDefinitions="auto,*" ColumnSpacing="12">
                            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{toolkit:AppThemeResource TextBox}" Padding="8" WidthRequest="48" HeightRequest="48">
                                <Image Source="{Binding NFT.TokenInfo.Icon, TargetNullValue=tokens_icon_default.png}" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding NFT.Name}" FontAttributes="Bold" FontSize="17" />
                                <Label StyleClass="Secondary" Text="{Binding NFT.TokenInfo.Name}" FontSize="12" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="8">
                    <Label StyleClass="Secondary" Text="{x:Static og:Strings.ReceivingAddress}" FontAttributes="Bold" />
                    <Border StyleClass="Field">
                        <Grid ColumnDefinitions="*,auto,auto" ColumnSpacing="8">
                            <Entry x:Name="entryAddress" Text="{Binding ToAddress}" ClearButtonVisibility="Never" og:Border.IsVisible="False" />
                            <Button Grid.Column="1" StyleClass="Icon, IconSecondary" Text="&#xe60d;" FontSize="22" Padding="8" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" Clicked="OnSelectContact" />
                            <Button Grid.Column="2" StyleClass="Icon, IconSecondary" Text="&#xe69a;" FontSize="26" Padding="8" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" Command="{x:Static og:Commands.ScanQRCode}" CommandParameter="?action=RecognizeAddress" />
                        </Grid>
                    </Border>
                    <og:ValidationMessage Title="{x:Static og:Strings.ReceivingAddress}" Target="{x:Reference entryAddress}">
                        <og:Required />
                        <og:Custom Validate="OnValidateAddress" />
                    </og:ValidationMessage>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        <og:Submit Grid.Row="1" Text="{x:Static og:Strings.Continue}" Submitted="OnSubmitted" />
    </Grid>
</ContentPage>
