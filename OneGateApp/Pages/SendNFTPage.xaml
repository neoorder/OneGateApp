<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="NeoOrder.OneGate.Pages.SendNFTPage"
             Title="{x:Static og:Strings.Send}"
             SafeAreaEdges="All"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <Grid Margin="20" RowDefinitions="*,auto">
        <VerticalStackLayout Spacing="20">
            <Label StyleClass="Secondary" Text="NFT" />
            <Border StrokeShape="RoundRectangle 5" Margin="0,-16,0,0">
                <Grid ColumnDefinitions="auto,*" ColumnSpacing="10" Padding="10" BackgroundColor="{toolkit:AppThemeResource TextBox}">
                    <Image Source="{Binding NFT.TokenInfo.Icon, TargetNullValue=tokens_icon_default.png}" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" AutomationProperties.IsInAccessibleTree="False" />
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="{Binding NFT.Name}" FontAttributes="Bold" FontSize="16" />
                        <Label StyleClass="Secondary" Text="{Binding NFT.TokenInfo.Name}" FontSize="12" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
            <Label StyleClass="Secondary" Text="{x:Static og:Strings.ReceivingAddress}" />
            <Border StrokeShape="RoundRectangle 5" Margin="0,-16,0,0">
                <Grid ColumnDefinitions="*,auto,auto" Padding="10,5" BackgroundColor="{toolkit:AppThemeResource TextBox}">
                    <Entry x:Name="entryAddress" Text="{Binding ToAddress}" ClearButtonVisibility="Never" og:Border.IsVisible="False" SemanticProperties.Description="{x:Static og:Strings.ReceivingAddress}" />
                    <Button Grid.Column="1" StyleClass="Icon, IconSecondary" Text="&#xe60d;" FontSize="22" Margin="0,-10" Padding="10" VerticalOptions="Center" SemanticProperties.Description="{x:Static og:Strings.SelectContact}" Clicked="OnSelectContact" />
                    <Button Grid.Column="2" StyleClass="Icon, IconSecondary" Text="&#xe69a;" FontSize="28" Margin="0,-10" Padding="10" VerticalOptions="Center" SemanticProperties.Description="{x:Static og:Strings.ScanQRCode}" Command="{x:Static og:Commands.ScanQRCode}" CommandParameter="?action=RecognizeAddress" />
                </Grid>
            </Border>
            <og:ValidationMessage Title="{x:Static og:Strings.ReceivingAddress}" Margin="0,-16,0,0" Target="{x:Reference entryAddress}">
                <og:Required />
                <og:Custom Validate="OnValidateAddress" />
            </og:ValidationMessage>
        </VerticalStackLayout>
        <og:Submit Grid.Row="1" Text="{x:Static og:Strings.Continue}" Submitted="OnSubmitted" />
    </Grid>
</ContentPage>
