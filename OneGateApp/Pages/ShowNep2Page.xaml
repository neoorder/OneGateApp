<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="NeoOrder.OneGate.Pages.ShowNep2Page"
             Title="{x:Static og:Strings.ExportPrivateKey}"
             SafeAreaEdges="All"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Margin="20" Spacing="20">
            <Label StyleClass="Icon" Text="&#xe744;" FontSize="50" HorizontalOptions="Center" />
            <Label Text="{x:Static og:Strings.PrivateKeySecurity}" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="{x:Static og:Strings.Nep2PrivateKeyWarning}" />
            <Label StyleClass="Secondary" Text="{x:Static og:Strings.SetPassword}" />
            <Entry x:Name="entryPassword" Text="{Binding Password}" IsPassword="True" ReturnType="Next" Margin="0,-20,0,0" />
            <og:ValidationMessage Title="{x:Static og:Strings.Password}" Margin="0,-20,0,0" Target="{Binding Password}">
                <og:Required />
                <og:StringLength Min="6" Max="20" />
            </og:ValidationMessage>
            <Label StyleClass="Secondary" Text="{x:Static og:Strings.RepeatPassword}" />
            <Entry x:Name="entryRepeat" IsPassword="True" Margin="0,-20,0,0" />
            <og:ValidationMessage Margin="0,-20,0,0" Target="{x:Reference entryRepeat}">
                <og:Compare To="{Binding Password}" ErrorMessage="{x:Static og:Strings.ErrorMessagePasswordsMismatch}" />
            </og:ValidationMessage>
            <Label StyleClass="Secondary" Text="{x:Static og:Strings.PasswordProtectedPrivateKeyNep2}" />
            <Border Padding="10" StrokeShape="RoundRectangle 5" BackgroundColor="{toolkit:AppThemeResource TextBox}" AutomationProperties.ExcludedWithChildren="True">
                <Editor x:Name="editorPrivateKey" Text="{Binding PrivateKey}" Placeholder="{x:Static og:Strings.ShownAfterSettingPassword}" IsReadOnly="True" HeightRequest="60" og:Border.IsVisible="False" />
            </Border>
            <og:Submit Text="{x:Static og:Strings.ExportPrivateKey}" Submitted="OnSubmit" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
