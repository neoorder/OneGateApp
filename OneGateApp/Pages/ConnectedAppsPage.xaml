<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:NeoOrder.OneGate.Models"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="NeoOrder.OneGate.Pages.ConnectedAppsPage"
             Title="{x:Static og:Strings.ConnectedApps}"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{x:Static og:Strings.Clear}" IsEnabled="{Binding HasConnectedApps}" Clicked="OnDisconnectAllClicked" />
    </ContentPage.ToolbarItems>
    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
        <Grid RowDefinitions="auto,*" RowSpacing="18" Margin="20">
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="{toolkit:AppThemeResource Panel}" Padding="18">
                <Grid ColumnDefinitions="auto,*" ColumnSpacing="14">
                    <Border StrokeShape="Ellipse" BackgroundColor="{toolkit:AppThemeResource Primary}" WidthRequest="48" HeightRequest="48" VerticalOptions="Start">
                        <Label StyleClass="Icon" Text="&#xe60c;" TextColor="{toolkit:AppThemeResource Accent}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="{x:Static og:Strings.ConnectedDApps}" FontAttributes="Bold" FontSize="20" />
                        <Label StyleClass="Secondary" Text="{Binding SummaryText}" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <CollectionView Grid.Row="1" ItemsSource="{Binding ConnectedApps}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Grid RowDefinitions="*,*">
                        <VerticalStackLayout Spacing="18" VerticalOptions="Center">
                            <Border StrokeShape="Ellipse" BackgroundColor="#e9eaee" WidthRequest="100" HeightRequest="100">
                                <Image Source="empty.png" WidthRequest="32" HeightRequest="32" />
                            </Border>
                            <Label Text="{x:Static og:Strings.NoConnectedDApps}" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center" />
                            <Label StyleClass="Secondary" Text="{x:Static og:Strings.ConnectedAppsEmptyText}" Margin="0,-10,0,0" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ConnectedDApp">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="{x:Static og:Strings.Disconnect}" BackgroundColor="#d9534f" Clicked="OnDisconnectClicked" CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border StrokeShape="RoundRectangle 10" BackgroundColor="{toolkit:AppThemeResource Panel}" Padding="16">
                                <Grid ColumnDefinitions="auto,*,auto" RowDefinitions="auto,auto,auto,auto,auto" ColumnSpacing="12" RowSpacing="5">
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#e9edf8" WidthRequest="42" HeightRequest="42" VerticalOptions="Start">
                                        <Label StyleClass="Icon" Text="&#xe60c;" TextColor="#5676e7" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Column="1" Text="{Binding DisplayName}" FontAttributes="Bold" MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Button Grid.Column="2" Grid.RowSpan="4" StyleClass="Icon, IconSecondary" Text="&#xe605;" Margin="-10" Padding="10" VerticalOptions="Start" Clicked="OnMenuClicked" CommandParameter="{Binding Source={RelativeSource AncestorType={x:Type SwipeView}}}" />
                                    <Label Grid.Column="1" Grid.Row="1" Text="{Binding Domain}" StyleClass="Secondary" FontSize="12" MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding ConnectedAtText}" StyleClass="Secondary" FontSize="12" />
                                    <Label Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding LastUsedAtText}" StyleClass="Secondary" FontSize="12" />
                                    <FlexLayout Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="4" Margin="0,8,0,0" Wrap="Wrap" Direction="Row" AlignItems="Start">
                                        <Border StrokeShape="RoundRectangle 8" BackgroundColor="#eef2ff" Padding="8,5" Margin="0,0,8,8">
                                            <Label Text="{x:Static og:Strings.ConnectedAppsAccountReadPermission}" TextColor="#4263c4" FontSize="11" />
                                        </Border>
                                        <Border StrokeShape="RoundRectangle 8" BackgroundColor="#f6f1e7" Padding="8,5" Margin="0,0,8,8">
                                            <Label Text="{x:Static og:Strings.ConnectedAppsApprovalRequiredPermission}" TextColor="#8a641b" FontSize="11" />
                                        </Border>
                                    </FlexLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </RefreshView>
</ContentPage>
