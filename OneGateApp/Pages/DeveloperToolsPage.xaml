<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.DeveloperToolsPage"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Title="{x:Static og:Strings.DeveloperTools}"
             Shell.TabBarIsVisible="False">
    <VerticalStackLayout Margin="20" Spacing="20">
        <Label StyleClass="Secondary" Text="{x:Static og:Strings.DAppTesting}" />
        <Entry Margin="0,-20,0,0" Keyboard="Url" ReturnType="Go" ReturnCommand="{Binding DAppTestingCommand}" ReturnCommandParameter="{Binding Text, Source={RelativeSource Self}}" />
    </VerticalStackLayout>
</ContentPage>