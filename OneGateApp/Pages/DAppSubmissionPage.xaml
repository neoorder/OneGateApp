<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.DAppSubmissionPage"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Title="{x:Static og:Strings.DAppSubmission}"
             Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,auto">
        <ScrollView>
            <VerticalStackLayout Margin="20" Spacing="20">
                <Entry Text="{Binding SubmissionProjectName}" Placeholder="{x:Static og:Strings.ProjectName}" />
                <Editor Text="{Binding SubmissionIntroduction}" Placeholder="{x:Static og:Strings.Introduction}" AutoSize="TextChanges" MinimumHeightRequest="80" />
                <Entry Text="{Binding SubmissionUrl}" Placeholder="{x:Static og:Strings.DAppUrl}" Keyboard="Url" />
                <Entry Text="{Binding SubmissionWebsite}" Placeholder="{x:Static og:Strings.OfficialWebsite}" Keyboard="Url" />
                <Entry Text="{Binding SubmissionContact}" Placeholder="{x:Static og:Strings.ContactInformation}" />
            </VerticalStackLayout>
        </ScrollView>
        <Button Grid.Row="1" Margin="20" Text="{x:Static og:Strings.SubmitByEmail}" Clicked="OnSubmitDAppClicked" />
    </Grid>
</ContentPage>